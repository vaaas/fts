#!/bin/sh
# fts - full-text search over a folder of markdown documents, powered by sqlite3.
set -eu

FTS_DOCS="${FTS_DOCS:-./doc}"
FTS_DB="${FTS_DB:-./.fts.db}"
LIMIT=10
# FTS5 clamps a non-discriminative term's IDF to 1e-6, so a document that
# matched only such terms scores about that much regardless of corpus. The
# default sits above that floor to drop those junk matches, and no higher:
# bm25 is unnormalised, so a larger absolute cutoff would not travel between
# corpora. Precision comes from bm25 ranking, not this threshold.
MIN_SCORE=0.001
DO_INIT=0

# bm25 relevance, negated so that higher means more relevant. One weight per
# column (path is unindexed), so title and tag hits outrank plain body text.
SCORE="-bm25(docs, 0.0, 10.0, 5.0, 1.0)"

# A sample of body text around the match, whitespace flattened to a single line
# so each result is one `path:text` line, like grep.
SNIPPET="trim(replace(replace(snippet(docs, 3, '', '', '…', 16), char(10), ' '), char(9), ' '))"

usage() {
	cat <<'EOF'
Usage:
  fts -i [-d DIR] [-b FILE]   Build the search index from markdown files.
  fts [options] QUERY...      Search the index, best matches first.
  fts PATH                    Print a document (argument is an existing file).

Options:
  -i         Build (initialise) the search index.
  -n N       Maximum number of results (default 10).
  -s S       Minimum relevance score (default 0.001, drops junk matches).
  -d DIR     Documents folder (default ./doc, or $FTS_DOCS).
  -b FILE    Index database file (default ./.fts.db, or $FTS_DB).
  -h         Show this help.

Tags:
  Words written as #tag in a document are indexed and weighted highly, so
  `fts backend` surfaces documents tagged #backend.
EOF
}

die() {
	echo "fts: $1" >&2
	exit "${2:-1}"
}

# Double single quotes so a value is safe inside an SQL '...' literal.
sql_escape() {
	printf '%s' "$1" | sed "s/'/''/g"
}

# Emit the transaction that rebuilds the index: one INSERT per markdown file,
# with the body loaded straight from disk by sqlite3's readfile().
index_rebuild_sql() {
	echo 'BEGIN;'
	echo 'DROP TABLE IF EXISTS docs;'
	echo "CREATE VIRTUAL TABLE docs USING fts5(path UNINDEXED, title, tags, body, tokenize = 'porter unicode61');"
	find "$FTS_DOCS" -type f -name '*.md' | sort | while IFS= read -r file
	do
		title=$(sed -n 's/^# *//p' "$file" | head -n 1)
		test -n "$title" || title=$(basename "$file")
		tags=$(grep -oE '#[A-Za-z0-9]+' "$file" | sed 's/^#//' | sort -u | tr '\n' ' ')

		escaped_path=$(sql_escape "$file")
		printf "INSERT INTO docs(path,title,tags,body) VALUES('%s','%s','%s',readfile('%s'));\n" \
			"$escaped_path" "$(sql_escape "$title")" "$(sql_escape "$tags")" "$escaped_path"
	done
	echo 'COMMIT;'
}

build_index() {
	test -d "$FTS_DOCS" || die "documents folder not found: $FTS_DOCS"
	index_rebuild_sql | sqlite3 "$FTS_DB"
	echo "indexed $(sqlite3 "$FTS_DB" 'SELECT count(*) FROM docs') document(s) into $FTS_DB"
}

# Turn free-text query words into a safe FTS5 MATCH expression.
# Words are joined with OR so any single term can match; bm25 then ranks
# documents matching more (and rarer) terms highest. A leading '#' is
# stripped so `#backend` and `backend` behave identically.
build_match() {
	match=''
	for word in "$@"
	do
		word=$(printf '%s' "$word" | sed 's/^#//; s/"/""/g')
		test -n "$word" || continue
		test -z "$match" || match="$match OR"
		match="$match \"$word\""
	done
	printf '%s' "$match"
}

search() {
	test -f "$FTS_DB" || die "index not found: $FTS_DB (run: fts -i)"
	test "$#" -gt 0 || die "no query given (try: fts -h)"

	match=$(build_match "$@")
	test -n "$match" || die "empty query after parsing"
	escaped_match=$(sql_escape "$match")

	sqlite3 -batch -noheader "$FTS_DB" <<SQL
SELECT path || ':' || $SNIPPET
FROM docs
WHERE docs MATCH '$escaped_match'
  AND $SCORE >= $MIN_SCORE
ORDER BY $SCORE DESC
LIMIT $LIMIT;
SQL
}

# Leading ':' puts getopts in silent mode so we report errors ourselves.
while getopts ':in:s:d:b:h' option
do
	case "$option" in
		i) DO_INIT=1 ;;
		n) LIMIT="$OPTARG" ;;
		s) MIN_SCORE="$OPTARG" ;;
		d) FTS_DOCS="$OPTARG" ;;
		b) FTS_DB="$OPTARG" ;;
		h) usage; exit 0 ;;
		:) die "-$OPTARG requires a value" 2 ;;
		?) die "unknown option: -$OPTARG" 2 ;;
	esac
done
shift $((OPTIND - 1))

if test "$DO_INIT" -eq 1
then
	build_index
	exit 0
fi

# Convenience: a single argument that is an existing file is printed, not searched.
if test "$#" -eq 1 && test -f "$1"
then
	cat "$1"
	exit 0
fi

search "$@"
